{
	"name": "open-docref-vscode",
	"displayName": "open-docref",
	"description": "Anchor documentation to code: create docrefs from selections, see drift in the editor.",
	"version": "0.1.0",
	"publisher": "manchtools",
	"license": "MIT",
	"type": "module",
	"icon": "icon.png",
	"homepage": "https://github.com/manchtools/open-docref#readme",
	"bugs": "https://github.com/manchtools/open-docref/issues",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/manchtools/open-docref.git",
		"directory": "packages/vscode"
	},
	"keywords": [
		"documentation",
		"docs-as-code",
		"drift",
		"markdown",
		"codelens"
	],
	"engines": {
		"vscode": "^1.90.0"
	},
	"categories": [
		"Other"
	],
	"main": "./dist/extension.cjs",
	"scripts": {
		"vscode:prepublish": "cd ../.. && bun run build:ext"
	},
	"activationEvents": [
		"onStartupFinished"
	],
	"contributes": {
		"commands": [
			{
				"command": "docref.createAnchor",
				"title": "Docref: Create Anchor from Selection"
			},
			{
				"command": "docref.rescan",
				"title": "Docref: Rescan",
				"icon": "$(refresh)"
			},
			{
				"command": "docref.refreshSnippets",
				"title": "Docref: Refresh Stale Snippets",
				"icon": "$(sync)"
			},
			{
				"command": "docref.approveClaims",
				"title": "Docref: Approve Claims in Current Document"
			},
			{
				"command": "docref.showDrift",
				"title": "Docref: Show Claim Drift"
			},
			{
				"command": "docref.stageSelection",
				"title": "Docref: Stage Reference from Selection"
			},
			{
				"command": "docref.stageRef",
				"title": "Stage Reference"
			},
			{
				"command": "docref.unstage",
				"title": "Unstage",
				"icon": "$(close)"
			},
			{
				"command": "docref.clearStage",
				"title": "Docref: Clear Staged",
				"icon": "$(clear-all)"
			},
			{
				"command": "docref.insertClaim",
				"title": "Insert Claim at Cursor",
				"icon": "$(note)"
			},
			{
				"command": "docref.insertSnippet",
				"title": "Insert Snippet at Cursor",
				"icon": "$(code)"
			},
			{
				"command": "docref.removeEverywhere",
				"title": "Delete Reference Everywhere"
			}
		],
		"menus": {
			"editor/context": [
				{
					"command": "docref.createAnchor",
					"when": "editorHasSelection",
					"group": "docref"
				},
				{
					"command": "docref.approveClaims",
					"when": "resourceExtname == .md",
					"group": "docref"
				},
				{
					"command": "docref.showDrift",
					"when": "resourceExtname == .md",
					"group": "docref"
				},
				{
					"command": "docref.stageSelection",
					"when": "editorHasSelection",
					"group": "docref"
				}
			],
			"view/title": [
				{
					"command": "docref.rescan",
					"when": "view == docrefRefs",
					"group": "navigation"
				},
				{
					"command": "docref.refreshSnippets",
					"when": "view == docrefRefs",
					"group": "navigation"
				},
				{
					"command": "docref.rescan",
					"when": "view == docrefAnchors",
					"group": "navigation"
				},
				{
					"command": "docref.clearStage",
					"when": "view == docrefStaged",
					"group": "navigation"
				}
			],
			"view/item/context": [
				{
					"command": "docref.stageRef",
					"when": "viewItem == hasRef",
					"group": "docref@1"
				},
				{
					"command": "docref.removeEverywhere",
					"when": "viewItem == hasRef",
					"group": "docref@2"
				},
				{
					"command": "docref.insertClaim",
					"when": "view == docrefStaged && viewItem == staged",
					"group": "inline@1"
				},
				{
					"command": "docref.insertSnippet",
					"when": "view == docrefStaged && viewItem == staged",
					"group": "inline@2"
				},
				{
					"command": "docref.unstage",
					"when": "view == docrefStaged && viewItem == staged",
					"group": "inline@3"
				},
				{
					"command": "docref.removeEverywhere",
					"when": "view == docrefStaged && viewItem == staged",
					"group": "docref@1"
				}
			]
		},
		"viewsContainers": {
			"activitybar": [
				{
					"id": "docref",
					"title": "Docref",
					"icon": "icon.svg"
				}
			]
		},
		"views": {
			"docref": [
				{
					"id": "docrefRefs",
					"name": "References"
				},
				{
					"id": "docrefAnchors",
					"name": "Anchors in Code"
				},
				{
					"id": "docrefStaged",
					"name": "Staged"
				}
			]
		},
		"viewsWelcome": [
			{
				"view": "docrefStaged",
				"contents": "Stage a reference to insert it into a document with its hash precomputed.\n[Stage Current Selection](command:docref.stageSelection)\nOr right-click any reference in the views above."
			}
		]
	},
	"devDependencies": {
		"@open-docref/core": "workspace:*",
		"@types/vscode": "^1.90.0"
	}
}
